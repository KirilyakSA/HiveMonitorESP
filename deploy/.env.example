# HiveMonitor Docker Compose environment.
# Copy this file to deploy/.env and replace secrets before production use.

POSTGRES_DB=hivemonitor
POSTGRES_USER=hivemonitor
POSTGRES_PASSWORD=replace-with-long-random-password

# Keep host/service names as-is for Docker Compose internal network.
DATABASE_URL=postgres://hivemonitor:replace-with-long-random-password@postgres:5432/hivemonitor?sslmode=disable

HTTP_ADDR=:8080
JWT_SECRET=replace-with-64-plus-random-characters
ACCESS_TOKEN_TTL_MINUTES=1440

NATS_URL=nats://nats:4222

MQTT_BROKER_URL=tcp://mosquitto:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=hivemonitor-mqtt-ingestion
MQTT_TELEMETRY_TOPIC=hives/+/telemetry,apiaries/+/devices/+/telemetry,hives/+/events,apiaries/+/devices/+/events,hives/+/status,apiaries/+/devices/+/status

DEFAULT_APIARY_ID=
DEFAULT_TELEMETRY_INTERVAL_MINUTES=30
